# Copy this file to .streamlit/secrets.toml (gitignored) and fill in your
# real Neon connection string. Alternatively, set DATABASE_URL as an
# environment variable instead of using this file.
#
# IMPORTANT: never edit .streamlit/secrets.toml through a Git-tracked
# rename/commit of this file — create it as a separate, untracked file.

DATABASE_URL = "postgresql://<user>:<password>@<endpoint>.neon.tech/<dbname>?sslmode=require"
